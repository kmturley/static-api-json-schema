{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "@context": {
      "type": "string"
    },
    "@type": {
      "type": "string",
      "const": "SoftwareSourceCode"
    },
    "@id": {
      "type": "string",
      "format": "uri"
    },
    "name": {
      "type": "string"
    },
    "version": {
      "type": "string"
    },
    "datePublished": {
      "type": "string"
    },
    "releaseNotes": {
      "type": "string"
    },
    "isPartOf": {
      "type": "object",
      "properties": {
        "@id": {
          "type": "string",
          "format": "uri"
        },
        "@type": {
          "type": "string",
          "const": "SoftwareApplication"
        }
      },
      "required": [
        "@id",
        "@type"
      ],
      "additionalProperties": false
    },
    "distribution": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "@type": {
            "type": "string",
            "const": "DataDownload"
          },
          "name": {
            "type": "string"
          },
          "contentUrl": {
            "type": "string",
            "format": "uri"
          },
          "encodingFormat": {
            "type": "string"
          },
          "license": {
            "type": "string",
            "format": "uri"
          },
          "operatingSystem": {
            "type": "string"
          }
        },
        "required": [
          "@type",
          "name",
          "contentUrl",
          "encodingFormat",
          "license"
        ],
        "additionalProperties": false
      }
    }
  },
  "required": [
    "@context",
    "@type",
    "@id",
    "name",
    "version",
    "datePublished",
    "releaseNotes",
    "isPartOf",
    "distribution"
  ],
  "additionalProperties": false,
  "$id": "https://kmturley.github.io/static-api-json-schema/schema/games/versions"
}