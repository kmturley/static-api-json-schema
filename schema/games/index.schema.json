{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "@context": {
      "type": "string"
    },
    "@type": {
      "type": "string",
      "const": "SoftwareApplication"
    },
    "@id": {
      "type": "string",
      "format": "uri"
    },
    "name": {
      "type": "string"
    },
    "description": {
      "type": "string"
    },
    "applicationCategory": {
      "type": "string"
    },
    "keywords": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "publisher": {
      "type": "object",
      "properties": {
        "@id": {
          "type": "string",
          "format": "uri"
        },
        "@type": {
          "type": "string",
          "const": "Organization"
        }
      },
      "required": [
        "@id",
        "@type"
      ],
      "additionalProperties": false
    },
    "url": {
      "type": "string",
      "format": "uri"
    },
    "image": {
      "anyOf": [
        {
          "type": "string",
          "format": "uri"
        },
        {
          "type": "null"
        }
      ]
    },
    "versions": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "@id": {
            "type": "string",
            "format": "uri"
          },
          "@type": {
            "type": "string",
            "const": "SoftwareSourceCode"
          }
        },
        "required": [
          "@id",
          "@type"
        ],
        "additionalProperties": false
      }
    },
    "latestVersion": {
      "anyOf": [
        {
          "type": "object",
          "properties": {
            "@id": {
              "type": "string",
              "format": "uri"
            },
            "@type": {
              "type": "string",
              "const": "SoftwareSourceCode"
            }
          },
          "required": [
            "@id",
            "@type"
          ],
          "additionalProperties": false
        },
        {
          "type": "null"
        }
      ]
    }
  },
  "required": [
    "@context",
    "@type",
    "@id",
    "name",
    "description",
    "applicationCategory",
    "keywords",
    "publisher",
    "url",
    "image",
    "versions",
    "latestVersion"
  ],
  "additionalProperties": false,
  "$id": "https://kmturley.github.io/static-api-json-schema/schema/games"
}