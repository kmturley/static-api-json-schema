{
  "name": "static-api-json-schema",
  "version": "0.1.0",
  "type": "module",
  "description": "Transform yaml into schema.org-compatible JSON-LD files and deploy as a static API.",
  "scripts": {
    "build": "node --import tsx ./src/core/cli.ts build",
    "clean": "node --import tsx ./src/core/cli.ts clean",
    "dev": "node --import tsx ./src/core/cli.ts dev",
    "test": "node --import tsx --test ./test/engine.test.ts",
    "typecheck": "tsc --noEmit",
    "validate": "node --import tsx ./src/core/cli.ts validate",
    "compile": "tsc -p tsconfig.json"
  },
  "dependencies": {
    "yaml": "^2.8.1",
    "zod": "^4.1.5"
  },
  "devDependencies": {
    "@types/node": "^24.3.0",
    "tsx": "^4.20.5",
    "typescript": "^5.9.2"
  }
}
